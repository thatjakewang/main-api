# Copy to .env and fill in real values. See README.md for details.

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:port/dbname

# API key required by all protected (write / AI) endpoints via the x-api-key header
SHORTCUT_API_KEY=your_api_key

# OpenAI (only needed for the AI expense summary endpoints)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.4-mini

# Timezone used for "today" / "current month" calculations
APP_TIMEZONE=Asia/Taipei

# Budget context for the monthly AI summary (commas allowed, e.g. 80,000)
MONTHLY_INCOME=80000
MONTHLY_FIXED_EXPENSES=35000

# Seed odometer value, used only until the first POST /api/tesla/odometer
TESLA_ODOMETER_KM=21471
